{
  "name": "piratas-club-vault",
  "version": "1.0.0",
  "description": "Piratas.Club Vault - Uma coleção organizada de recursos, ferramentas e informações úteis",
  "homepage": "https://piratas.club",
  "license": "MIT",
  "author": {
    "name": "Pablo Murad",
    "email": "pablomurad@pm.me"
  },
  "type": "module",
  "scripts": {
    "build": "vitepress build docs",
    "dev": "vitepress dev docs",
    "preview": "vitepress preview docs",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy docs/.vitepress/dist --project-name=piratasclub",
    "lint": "eslint docs/.vitepress/config.ts --ext .ts,.js || true",
    "lint:fix": "eslint docs/.vitepress/config.ts --ext .ts,.js --fix || true",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:run": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "ci": "npm run type-check && npm run lint && npm run test:run && npm run build",
    "migrate-links": "node scripts/migrate-links.mjs"
  },
  "keywords": [
    "documentation",
    "vault",
    "resources",
    "tools",
    "vitepress",
    "piratas-club"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/runawaydevil/runawaydevil.github.io"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.397",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vue/compiler-sfc": "^3.5.22",
    "eslint": "^8.0.0",
    "fast-check": "^4.4.0",
    "jest": "^30.2.0",
    "jsdom": "^27.3.0",
    "typescript": "^5.0.0",
    "unplugin-icons": "^22.4.2",
    "unplugin-vue-components": "^29.1.0",
    "vitepress": "^1.5.0",
    "vitepress-plugin-rss": "^0.3.2",
    "vue": "^3.5.22",
    "wrangler": "^4.45.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  }
}
